!.gitignore

# Track deployment automation and IaC
!deployment/
!deployment/**

# Local Docker image exports (large binaries; keep out of Git)
deployment/images/

# Service build/runtime artifacts (if any service paths are unignored)
**/bin/
**/obj/
**/out/
**/build/
**/dist/
**/coverage/
**/TestResults/
