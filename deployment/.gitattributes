# Auto detect text files and perform LF normalization
* text=auto

# Terraform files
*.tf text eol=lf
*.tfvars text eol=lf
*.hcl text eol=lf

# Shell scripts
*.sh text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text

# JSON
*.json text

# Ignore secrets and sensitive files
*.tfvars linguist-generated=true
*.secret linguist-generated=true
.env linguist-generated=true

